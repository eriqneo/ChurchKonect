# The current frontend runs without environment variables.
#
# Reserve this public Vite variable for the future PocketBase integration.
# Set it in Cloudflare Pages > Settings > Environment variables when the
# backend is ready. Never place PocketBase admin credentials in VITE_* values.
VITE_PB_URL=https://churchconnect.pockethost.io

# Development-only role controls are disabled by default. Real production
# authorization always comes from the PocketBase user record.
# VITE_ENABLE_ROLE_SIMULATOR=false
