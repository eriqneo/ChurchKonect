{
  "name": "churchconnect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "backend:bootstrap-auth": "node scripts/pocketbase/bootstrap-auth.mjs",
    "backend:bootstrap-members": "node scripts/pocketbase/bootstrap-members.mjs",
    "backend:bootstrap-cell-structure": "node scripts/pocketbase/bootstrap-cell-structure.mjs",
    "backend:bootstrap-cell-operations": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-cell-operations.mjs",
    "backend:bootstrap-training": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-training.mjs",
    "backend:bootstrap-announcements": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-announcements.mjs",
    "backend:bootstrap-prayer": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-prayer.mjs",
    "backend:bootstrap-reports": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-reports.mjs",
    "backend:bootstrap-notifications": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-notifications.mjs",
    "backend:bootstrap-governance": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-governance.mjs",
    "backend:bootstrap-saints-directory": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-saints-directory.mjs",
    "backend:bootstrap-home-dashboard": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-home-dashboard.mjs",
    "backend:bootstrap-account-linking": "node --dns-result-order=ipv4first scripts/pocketbase/bootstrap-account-linking.mjs",
    "backend:check-hooks": "node scripts/hooks/check-hooks.mjs",
    "backend:smoke-provisioning": "node --dns-result-order=ipv4first scripts/pocketbase/smoke-provision-member-account.mjs",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name churchkonect",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pocketbase": "^0.27.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
